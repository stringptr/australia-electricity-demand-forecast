# Host binding
HOST_IP=127.0.0.1

# PostgreSQL (shared across services)
POSTGRES_DB=electricity
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432

# VictoriaMetrics
VM_RETENTION=3M

# Garage (S3-compatible object storage)
GARAGE_ADMIN_TOKEN=changeme
GARAGE_BUCKET_AEMO=aemo-nemweb
AEMO_KEY_ID=aemo-key-id
AEMO_SECRET_KEY=aemo-secret-key
